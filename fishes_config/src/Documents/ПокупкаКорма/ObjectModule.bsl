#Область ОбработчикиСобытий
Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	Движения.ОстаткиПоРыбе.Записывать = Истина;
	
	ЗапросПоОстаткам = Новый Запрос;
	ЗапросПоОстаткам.Текст = 
		"ВЫБРАТЬ
		|	т.ПородаРыб КАК Порода,
		|	т.КоличествоОстаток КАК Количество
		|ИЗ
		|	РегистрНакопления.ОстаткиПоРыбе.Остатки(&МоментВремени, Аквариум = &Аквариум) КАК т
		|ГДЕ
		|	т.КоличествоОстаток > 0";
	ЗапросПоОстаткам.УстановитьПараметр("МоментВремени", МоментВремени());
	ЗапросПоОстаткам.УстановитьПараметр("Аквариум", Аквариум);
	Результат = ЗапросПоОстаткам.Выполнить();
	
	ОбщееКоличество = 0;
	Таблица = Результат.Выгрузить();
	
	Для Каждого Строка Из Таблица Цикл
		ОбщееКоличество = ОбщееКоличество + Строка.Количество;
	КонецЦикла;
		
	Если ОбщееКоличество <= 0 Тогда
		Возврат;
	КонецЕсли;
	
	Для Каждого Строка Из Таблица Цикл
		ДоляКорма = СтоимостьКорма * Строка.Количество / ОбщееКоличество;
		
		Движение = Движения.ОстаткиПоРыбе.Добавить();
		Движение.ВидДвижения = ВидДвиженияНакопления.Приход;
		Движение.Период = Дата;
		Движение.Аквариум = Аквариум;
		Движение.ПородаРыб = Строка.Порода;
		Движение.Количество = 0;
		Движение.Стоимость = ДоляКорма;
	КонецЦикла;
КонецПроцедуры
#КонецОбласти
